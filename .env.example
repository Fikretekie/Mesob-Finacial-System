# Environment: "staging" or "production"
# Determines which Cognito pool and app URL are used.
REACT_APP_ENV=staging

# ---------------------------------------------------------------------------
# App URL (used for Cognito callback/sign-out URLs)
# ---------------------------------------------------------------------------
