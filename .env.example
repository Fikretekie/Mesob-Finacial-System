REACT_APP_PRODUCTION_APP_URL=https://app.mesobfinancial.com

# ---------------------------------------------------------------------------
# Cognito – Staging (required when REACT_APP_ENV=staging)
# --------------------------------------------------------------------------
REACT_APP_STAGING_COGNITO_USER_POOL_ID=us-east-1_VpNtAU2i3
REACT_APP_STAGING_COGNITO_CLIENT_ID=49q7n30ga8dfr8gmh1vtfsf1e5
REACT_APP_STAGING_COGNITO_DOMAIN=us-east-1vpntau2i3.auth.us-east-1.amazoncognito.com
